# ─── Upstash Redis (wajib untuk production caching) ──────────────────────────
# Setup: https://upstash.com → Create Database → REST API tab
# Kalau tidak diisi, fallback ke in-memory cache (cache hilang tiap cold start)
UPSTASH_REDIS_REST_URL="https://YOUR-DB.upstash.io"
UPSTASH_REDIS_REST_TOKEN="YOUR_TOKEN_HERE"

# ─── (Legacy / tidak dipakai oleh proxy) ─────────────────────────────────────
GEMINI_API_KEY="MY_GEMINI_API_KEY"
APP_URL="MY_APP_URL"
